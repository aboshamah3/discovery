# ---- App ----
NODE_ENV=development
NEXT_PUBLIC_APP_NAME="DS Product Discovery"

# ---- Database (PostgreSQL) ----
# Point this at your PostgreSQL instance. On Railway, reference the Postgres
# plugin's connection string; locally, use any reachable Postgres.
DATABASE_URL="postgresql://user:password@localhost:5432/ds"

# ---- Product source ----
PRODUCTS_SOURCE_URL="https://media.downshift.app/hiring/founding-engineer/items.json"

# ---- Typesense (search) ----
# Point at your Typesense service (Railway service host, or any reachable host).
# Admin key is SERVER-SIDE ONLY. Never expose it to the browser (no NEXT_PUBLIC_*).
TYPESENSE_HOST="localhost"
TYPESENSE_PORT="8108"
TYPESENSE_PROTOCOL="http"
TYPESENSE_API_KEY="dev_typesense_key"
TYPESENSE_SEARCH_ONLY_API_KEY="dev_search_only_key_optional"
TYPESENSE_PRODUCTS_COLLECTION="products"

# ---- Import behavior (used by later specs) ----
IMPORT_BATCH_SIZE="500"
REINDEX_BATCH_SIZE="500"
