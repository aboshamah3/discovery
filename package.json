{
  "name": "ds-product-discovery",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "start": "pnpm --filter web start",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck && tsc -p tsconfig.json",
    "test": "vitest run",
    "db:migrate": "pnpm --filter @ds/db db:migrate",
    "import:products": "tsx scripts/import-products.ts",
    "reindex:products": "tsx scripts/reindex-products.ts",
    "smoke:search": "tsx scripts/smoke-search.ts"
  },
  "devDependencies": {
    "@ds/import": "workspace:*",
    "@ds/search": "workspace:*",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
